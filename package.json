{
  "name": "@usetransactional/react",
  "version": "0.1.1",
  "description": "Official React SDK for Transactional - Auth, Chat, Knowledge Base, and Forms components",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs",
      "require": "./dist/auth/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "import": "./dist/chat/index.mjs",
      "require": "./dist/chat/index.js"
    },
    "./kb": {
      "types": "./dist/kb/index.d.ts",
      "import": "./dist/kb/index.mjs",
      "require": "./dist/kb/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.mjs",
      "require": "./dist/forms/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:css": "cp src/styles/base.css dist/styles.css",
    "dev": "tsup --watch",
    "test": "vitest --run --passWithNoTests",
    "test:run": "vitest --run --passWithNoTests",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "transactional",
    "react",
    "auth",
    "chat",
    "knowledge-base",
    "forms",
    "widget",
    "sdk",
    "typescript",
    "nextjs"
  ],
  "author": "Transactional HQ <hello@usetransactional.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TransactionalHQ/react.git"
  },
  "homepage": "https://usetransactional.com/docs/react-sdk",
  "bugs": {
    "url": "https://github.com/TransactionalHQ/react/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.0.0",
    "postcss": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
